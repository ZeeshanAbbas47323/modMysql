# Copy to .env.local and fill in your ClipDrop credentials.
# Keys never reach the browser — the frontend calls /api/image/* only.
# Get a key at https://clipdrop.co/apis

# One key authorises every ClipDrop service:
CLIPDROP_API_KEY=

# Endpoint overrides (optional — sensible ClipDrop defaults are built in):
# CLIPDROP_REMOVE_BG_URL=https://clipdrop-api.co/remove-background/v1
# CLIPDROP_UPSCALE_URL=https://clipdrop-api.co/image-upscaling/v1/upscale
# CLIPDROP_REMOVE_TEXT_URL=https://clipdrop-api.co/remove-text/v1

# --- Google Fonts (full catalog, free) -------------------------------------
# The builder loads fonts via the free Google Fonts CSS API (no key needed).
# To expose the FULL catalog (~1,800 families) in the searchable picker, add a
# free Google Fonts Developer API key (Google Cloud → enable "Web Fonts
# Developer API" → create an API key). The key stays server-side.
# Without a key, the built-in curated font list is used.
GOOGLE_FONTS_API_KEY=

# --- AWS S3 (file storage) ---------------------------------------------------
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3_PRESIGN_TTL=900            # presigned URL lifetime in seconds (default 900)

# --- MySQL (database) --------------------------------------------------------
# Either a single connection string...
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/gangsheet
# ...or discrete vars (used when DATABASE_URL is unset):
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gangsheet
# DB_SSL=require                 # set for managed MySQL that requires TLS

# --- Auth ---------------------------------------------------------------------
# JWT signing secret for the httpOnly session cookie (64+ random hex):
AUTH_SECRET=
# Session cookie defaults to Secure (HTTPS-only) when NODE_ENV=production.
# If you deploy to plain HTTP (e.g. a bare IP with no TLS yet), set this to
# "false" or logins won't persist — the browser silently drops Secure cookies
# sent over HTTP. Set back to "true" (or remove) once HTTPS is in front.
# COOKIE_SECURE=false

# Bootstrap admins (server-side, comma-separated). Grants admin access even
# before the account's `role` column is set to 'admin' in the database.
ADMIN_EMAILS=you@example.com
