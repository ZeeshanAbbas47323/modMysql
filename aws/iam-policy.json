{
  "Version": "2012-10-17",
  "Comment": "Attach to the IAM user (access key/secret in env vars) or the EC2/ECS instance role. Replace YOUR_BUCKET_NAME.",
  "Statement": [
    {
      "Sid": "S3GangsheetStorage",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:DeleteObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::YOUR_BUCKET_NAME",
        "arn:aws:s3:::YOUR_BUCKET_NAME/*"
      ]
    }
  ]
}
